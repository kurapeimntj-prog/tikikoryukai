<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>第3回 地域の交流会：日進地域の未来を。みんなで描く</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;700&family=Shippori+Mincho:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans JP', sans-serif;
            scroll-behavior: smooth;
            -webkit-text-size-adjust: 100%;
        }
        .font-serif {
            font-family: 'Shippori Mincho', serif;
        }
        /* ヒーローエリアの背景設定（アップロードされた画像を設定） */
        .hero-bg {
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), 
                        url('https://lh3.googleusercontent.com/d/1-TUqy3hvtoqr8lh0Yjcbc0HUjKp7Ho7W');
            background-size: cover;
            background-position: center;
        }
        /* モバイルでのテキスト可読性向上 */
        .text-shadow {
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }
        .accent-border {
            border-left: 5px solid #2d5a27;
        }
    </style>
</head>
<body class="bg-stone-50 text-stone-800 antialiased">

    <!-- ヒーローセクション -->
    <header class="hero-bg min-h-[85vh] flex items-center justify-center text-white text-center px-6 py-12">
        <div class="max-w-2xl">
            <p class="text-lg md:text-2xl tracking-[0.2em] mb-4 opacity-90 font-serif text-shadow">第3回 地域の交流会</p>
            <h1 class="text-3xl md:text-6xl font-serif mb-6 leading-tight text-shadow">日進地域の未来を。<br>みんなで描く</h1>
            <p class="text-base md:text-xl font-light mb-10 font-serif text-shadow">2026年5月9日(土) 18:00開始</p>
            <div class="flex flex-col gap-4 items-center">
                <a href="#register" class="w-full sm:w-auto bg-[#2d5a27] hover:bg-[#1e3d1a] text-white px-10 py-5 rounded-full transition duration-300 font-bold shadow-2xl text-lg md:text-xl active:scale-95">
                    参加を申し込む
                </a>
            </div>
        </div>
    </header>

    <!-- 紹介セクション -->
    <section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
        <div class="accent-border pl-5 md:pl-8 mb-12">
            <h2 class="text-xl md:text-3xl font-serif mb-6 text-[#2d5a27] leading-relaxed">なぜ人が住み続けるのか。<br>その魅力と地域力を探る。</h2>
            <p class="leading-relaxed text-stone-600 text-sm md:text-base">
                大宮のすぐ北にありながら、独自の歴史と共同体文化を育んできた日進。宮原や土呂とは異なる「暮らしを整える街」としての魅力について、地域に住む人たちがと共に意見交換を行い、未来を描きます。
            </p>
        </div>
    </section>

    <!-- 開催概要セクション -->
    <section class="bg-white py-16 md:py-24 shadow-inner">
        <div class="max-w-4xl mx-auto px-6">
            <h3 class="text-center font-serif text-2xl md:text-3xl mb-12 border-b-2 border-stone-100 pb-4 inline-block mx-auto w-full">開催概要</h3>
            
            <div class="grid md:grid-cols-2 gap-10 md:gap-16 mt-8">
                <!-- 左カラム：基本情報 -->
                <div class="space-y-8">
                    <div class="flex gap-4">
                        <div class="shrink-0 w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center text-[#2d5a27]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-[#2d5a27] text-lg mb-1">日時</h4>
                            <p class="text-stone-700 leading-relaxed text-sm md:text-base">
                                2026年5月9日(土)<br>
                                <span class="inline-block mt-1">第1部 18:00 - 19:00 (勉強会)</span><br>
                                <span class="inline-block">第2部 19:00 - 21:00 (交流会)</span>
                            </p>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <div class="shrink-0 w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center text-[#2d5a27]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-[#2d5a27] text-lg mb-1">会場</h4>
                            <p class="text-stone-700 leading-relaxed text-sm md:text-base">食べ処 さぼちゃん</p>
                            <p class="text-xs text-stone-500 mb-2">JR日進駅徒歩6分 / JR宮原駅徒歩10分</p>
                            <a href="https://share.google/MoQddaJwO6g9JmTSc" target="_blank" class="text-green-700 hover:underline text-xs font-bold inline-flex items-center">
                                Googleマップを開く
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
                
                <!-- 右カラム：登壇者 -->
                <div class="bg-stone-50 p-6 md:p-8 rounded-2xl border border-stone-200">
                    <h4 class="font-serif text-lg md:text-xl mb-4 text-[#2d5a27] flex items-center">
                        <span class="mr-2">■</span>スピーカー紹介
                    </h4>
                    <ul class="space-y-4 text-sm md:text-base text-stone-700">
                        <li class="flex flex-col">
                            <span class="font-bold">野原 健志 氏</span>
                            <span class="text-xs text-stone-500">日進桜まつり実行委員長</span>
                        </li>
                        <li class="flex flex-col">
                            <span class="font-bold">吉成 竜之助 氏</span>
                            <span class="text-xs text-stone-500">日進大宮なび編集長</span>
                        </li>
                        <li class="flex flex-col border-none">
                            <span class="font-bold">片倉 淳平 氏</span>
                            <span class="text-xs text-stone-500">元さいたま市職員</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- 申し込みセクション -->
    <section id="register" class="py-20 px-6 text-center">
        <div class="max-w-2xl mx-auto">
            <h2 class="font-serif text-2xl md:text-4xl mb-6">参加申込み</h2>
            <p class="text-stone-600 mb-10 text-sm md:text-base leading-relaxed">
                日進地域の未来を共に語り合いましょう。<br class="hidden md:block">皆様のご参加を心よりお待ちしております。
            </p>
            
            <div class="bg-white rounded-3xl shadow-2xl border border-stone-100 overflow-hidden mb-8 max-w-sm mx-auto">
                <div class="bg-[#2d5a27] text-white py-4 font-bold text-base md:text-lg">
                    参加申込フォーム
                </div>
                <div class="p-8 md:p-10">
                    <p class="mb-8 text-sm text-stone-500 leading-relaxed italic">
                        ※外部フォーム（Googleフォーム）へ<br>移動します
                    </p>
                    <a href="https://forms.gle/wA824BcxD6E3px3H6" target="_blank" rel="noopener noreferrer" class="inline-block w-full bg-[#2d5a27] hover:bg-[#1e3d1a] text-white px-6 py-5 rounded-xl transition duration-300 font-bold text-lg md:text-xl shadow-md active:translate-y-1">
                        回答を入力する
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- 公式LINEセクション -->
    <section class="py-20 px-6 bg-[#06C755]/5 text-center">
        <div class="max-w-2xl mx-auto">
            <h2 class="font-serif text-2xl md:text-3xl mb-4">最新情報を受け取る</h2>
            <p class="text-stone-600 mb-10 text-sm md:text-base">
                公式LINEでは次回の開催案内や<br class="md:hidden">活動報告をお届けしています。
            </p>
            
            <a href="https://line.me/R/ti/p/@517ynoyv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-3 bg-[#06C755] hover:bg-[#05b14c] text-white px-8 py-5 rounded-2xl transition duration-300 font-bold text-lg md:text-xl shadow-xl w-full max-w-sm active:scale-95">
                <svg class="w-7 h-7 fill-current" viewBox="0 0 24 24">
                    <path d="M24 10.304c0-5.369-5.383-9.738-12-9.738-6.616 0-12 4.369-12 9.738 0 4.814 4.269 8.846 10.036 9.608.391.084.922.258 1.057.59.155.398.102 1.026.05 1.429-.19 1.557-.84 6.003-.966 6.89-.147.933.511.564 1.057.213 1.059-.677 5.727-3.483 7.82-5.891 1.616-1.846 2.861-3.8 3.007-5.845.047-.655.047-1.319.047-1.922zm-15.59 3.291c0 .421-.34.762-.761.762-.421 0-.762-.341-.762-.762v-4.522c0-.422.341-.762.762-.762.421 0 .761.34.761.762v4.522zm3.307 0c0 .421-.34.762-.761.762-.19 0-.363-.07-.492-.185l-1.547-1.392v.815c0 .421-.341.762-.762.762-.421 0-.762-.341-.762-.762v-4.522c0-.422.341-.762.762-.762.421 0 .762.34.762.762v.815l1.547 1.392v-.815c0-.422.341-.762.762-.762.421 0 .761.34.761.762v4.522zm3.307 0c0 .421-.34.762-.761.762h-1.785c-.421 0-.762-.341-.762-.762v-4.522c0-.422.341-.762.762-.762.421 0 .761.34.761.762v3.76h1.024c.421 0 .761.341.761.762zm3.307 0c0 .421-.34.762-.761.762h-1.785c-.421 0-.762-.341-.762-.762v-4.522c0-.422.341-.762.762-.762h1.785c.421 0 .761.34.761.762s-.34.762-.761.762h-1.024v.748h1.024c.421 0 .761.341.761.762s-.34.762-.761.762h-1.024v.74h1.024c.421 0 .761.341.761.762z"/>
                </svg>
                <span>友だち追加する</span>
            </a>
            
            <p class="mt-12 text-stone-500 text-sm italic">地域の交流をもっと身近に、もっと楽しく。</p>
            <p class="text-stone-400 text-xs mt-4">主宰：地域の交流会実行委員会</p>
        </div>
    </section>

    <!-- フッター -->
    <footer class="bg-stone-800 text-stone-500 py-10 text-center text-xs">
        <p>&copy; 2026 地域の交流会実行委員会</p>
    </footer>

</body>
</html>
